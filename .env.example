# Trading Agent — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ─── Exchanges ────────────────────────────────────────────────────────────────
# Binance API key — trade + read only, NEVER withdraw
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=false

# KuCoin API key — trade + read only
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=

# ─── LLM provider (OpenRouter recommended per CLAUDE.md §7) ───────────────────
# Use OpenRouter to keep trade data off DeepSeek's logs (~10-15% markup)
OPENROUTER_API_KEY=

# Or use DeepSeek direct (cheaper, but data goes to DeepSeek)
DEEPSEEK_API_KEY=

# Which provider the agent should use: "openrouter" or "deepseek"
LLM_PROVIDER=openrouter

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Create bot via @BotFather → bot token
TELEGRAM_BOT_TOKEN=
# Operator's personal chat ID (numeric, get from @userinfobot)
TELEGRAM_CHAT_ID=

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Path inside container where ~/.openclaw/ is mounted
OPENCLAW_HOME=/data/openclaw

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Force UTC inside the container regardless of host
TZ=UTC

# ─── Backup encryption ────────────────────────────────────────────────────────
# Passphrase for weekly encrypted backups (per CLAUDE.md §11 rule 9)
BACKUP_PASSPHRASE=
